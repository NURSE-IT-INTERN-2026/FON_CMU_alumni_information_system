generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DegreeLevel {
  DOCTORAL
  MASTER
  BACHELOR
  NURSING_ASSISTANT
}

enum AwardType {
  INTERNATIONAL
  NATIONAL
  LOCAL
}

enum NewsStatus {
  DRAFT
  PUBLISHED
}

model Alumni {
  id                    String    @id @default(uuid())
  studentId             String    @unique
  prefix                String
  firstName             String
  maidenLastName        String
  cohort                String?
  newLastName           String?
  degreeLevel           DegreeLevel
  province              String?
  email                 String?
  phone                 String?
  currentWorkplace      String?
  country               String?
  isPotential           Boolean   @default(false)
  isModelRepresentative Boolean   @default(false)
  photoUrl              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  awards               Award[]
  associations          Association[]
  graduateCommittees    GraduateCommittee[]
  potentials            Potential[]
  modelRepresentatives  ModelRepresentative[]
  abroadAlumni          AbroadAlumni[]

  @@map("alumni")
}

model Award {
  id            String    @id @default(uuid())
  studentId     String?
  recipientName String?
  awardName     String
  awardType     AwardType
  year          Int
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  alumni Alumni? @relation(fields: [studentId], references: [studentId], onDelete: Cascade)

  @@map("awards")
}

model Association {
  id              String   @id @default(uuid())
  studentId       String
  fullName        String
  associationName String
  position        String
  recordedYear    Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  alumni Alumni @relation(fields: [studentId], references: [studentId], onDelete: Cascade)

  @@unique([studentId, associationName, position, recordedYear])
  @@map("associations")
}

model GraduateCommittee {
  id        String   @id @default(uuid())
  termYear  Int
  studentId String
  fullName  String
  cohort    String
  position  String
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  alumni Alumni @relation(fields: [studentId], references: [studentId], onDelete: Cascade)

  @@unique([studentId, termYear, position])
  @@map("graduate_committees")
}

model News {
  id            String     @id @default(uuid())
  title         String
  body          String
  coverImageUrl String?
  status        NewsStatus @default(DRAFT)
  publishedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([title])
  @@map("news")
}

model Potential {
  id           String   @id @default(uuid())
  studentId    String
  fullName     String
  career       String
  position     String
  recordedYear Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  alumni Alumni @relation(fields: [studentId], references: [studentId], onDelete: Cascade)

  @@unique([studentId, recordedYear])
  @@map("potentials")
}

model ModelRepresentative {
  id         String   @id @default(uuid())
  studentId  String
  name       String
  cohort     String
  generation Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  alumni Alumni @relation(fields: [studentId], references: [studentId], onDelete: Cascade)

  @@unique([studentId, cohort, generation])
  @@map("model_representatives")
}

model AbroadAlumni {
  id         String   @id @default(uuid())
  studentId  String
  name       String
  address    String?
  country    String
  university String?
  order      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  alumni Alumni @relation(fields: [studentId], references: [studentId], onDelete: Cascade)

  @@unique([studentId, order])
  @@map("abroad_alumni")
}

model AdminUser {
  id           String    @id @default(uuid())
  firstName    String
  lastName     String
  email        String    @unique
  passwordHash String    @default("")
  role         String    @default("admin")
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions Session[]

  @@map("admin_users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}
