generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DegreeLevel {
  DOCTORAL
  MASTER
  BACHELOR
  NURSING_ASSISTANT
  ASSOCIATE
}

enum AwardType {
  INTERNATIONAL
  NATIONAL
  LOCAL
}

enum NewsStatus {
  DRAFT
  PUBLISHED
  DISCONTINUED
}

enum SessionType {
  ADMIN
  ALUMNI
}

enum ActorType {
  ADMIN
  ALUMNI
  SYSTEM
}

// Alumni account lifecycle for the admin-approval signup flow. New signups are
// UNVERIFIED until the alumni confirms email ownership (clicks the verification
// link), then PENDING until an admin reviews them; ACTIVE accounts may log in;
// REJECTED accounts are kept (re-approvable) but blocked from login. Default
// ACTIVE so pre-existing rows and CMU-only/imported rows (no credentials) are
// unaffected — login is additionally gated on `passwordHash`.
enum AccountStatus {
  UNVERIFIED
  PENDING
  ACTIVE
  REJECTED
}

model Alumni {
  id                    String      @id @default(uuid())
  studentId             String      @unique
  citizenId             String?
  birthDate             String?
  prefix                String
  firstName             String
  lastName              String
  nameManuallyUpdated   Boolean     @default(false)
  englishName           String?
  cohort                String?
  degreeLevel           DegreeLevel
  email                 String?     @unique
  // Contact email (for reaching the alumni) — DISTINCT from `email`, which is
  // the login/auth identity. Populated from the legacy dump via import.
  contactEmail          String?
  // One or more phone numbers (the legacy dump has landline + "มือถือ" mobile,
  // often comma-separated). Stored as a list, never a comma-clumped string.
  phones                String[]    @default([])
  major                 String?
  graduationYear        Int?
  primaryEducationId    String?  @unique
  homeAddress           String?
  remarks               String?
  isPotential           Boolean     @default(false)
  isModelRepresentative Boolean     @default(false)
  photoUrl              String?
  deletedAt             DateTime?
  suspendedAt           DateTime?
  hasLoggedIn           Boolean     @default(false)
  adminEditedAt         DateTime?
  passwordHash          String?
  lastLoginAt           DateTime?
  tosAcceptedAt         DateTime?
  cmuEmail              String?
  // Admin-approval signup flow: PENDING until reviewed. Snapshot of the
  // CMU Registrar comparison captured at signup — drives the admin's
  // field-by-field approve/review modal (null for accounts created otherwise).
  accountStatus         AccountStatus @default(ACTIVE)
  signupVerification    Json?
  // Set when the alumni confirmed email ownership (clicked the verification
  // link: UNVERIFIED → PENDING). Durable across later status changes; useful
  // for audit and future email-change re-verification.
  emailVerifiedAt       DateTime?
  // Latest admin rejection (reason + when). Set on reject, kept across a
  // re-application (REJECTED → reapply → PENDING) so the admin sees why they
  // rejected before, and cleared on approval. Full history lives in ActivityLog.
  rejectionReason       String?
  rejectedAt            DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  awards               Award[]
  associations         Association[]
  graduateCommittees   GraduateCommittee[]
  potentials           Potential[]
  modelRepresentatives ModelRepresentative[]
  alumniAgency         AlumniAgency[]
  passwordResets       PasswordReset[]
  emailVerifications   EmailVerification[]
  sessions             Session[]
  activityLogs         ActivityLog[]
  educations           Education[]
  primaryEducation     Education?  @relation("PrimaryEducation", fields: [primaryEducationId], references: [id], onDelete: SetNull)

  @@unique([citizenId])
  @@index([degreeLevel])
  @@index([cohort])
  @@index([major])
  @@index([graduationYear])
  @@index([accountStatus])
  @@map("alumni")
}

// One row per degree an alumni earned at FON. CMU Registrar returns one record
// per degree, so a person with a Bachelor's then a Doctoral has two rows here
// (distinct `studentId`, `degreeLevel`, `graduationYear`, `major`, `cohort`).
// `Alumni` keeps a denormalized "primary" snapshot of the chosen row
// (`studentId`/`degreeLevel`/`graduationYear`/`major`/`cohort` + the
// `primaryEducationId` pointer) so the 6 related tables (Award, Association, …)
// keep joining on `Alumni.studentId`. Keep that snapshot in sync via
// `syncPrimarySnapshot` (`lib/education-sync.ts`) — never edit it directly.
model Education {
  id             String      @id @default(uuid())
  alumniId       String
  studentId      String      @unique
  degreeLevel    DegreeLevel
  graduationYear Int?
  major          String?
  cohort         String?
  firstName      String?
  lastName       String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  alumni         Alumni      @relation(fields: [alumniId], references: [id], onDelete: Cascade)
  primaryFor     Alumni?     @relation("PrimaryEducation")

  @@unique([alumniId, degreeLevel])
  @@index([alumniId])
  @@map("education")
}

model Award {
  id            String    @id @default(uuid())
  studentId     String?
  // Attempted studentId that has no matching `Alumni` row yet — the "no Alumni
  // to link to" flag (see lib/alumni-link). `studentId` (FK below) stays null
  // while this is set; import moves it to `studentId` once a real Alumni appears.
  pendingStudentId String?
  prefix        String?
  firstName     String
  lastName      String
  awardName     String
  awardType     AwardType
  year          Int
  major         String?
  link          String?
  imageUrl      String?
  description   String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  alumni Alumni? @relation(fields: [studentId], references: [studentId], onDelete: Cascade)

  @@index([awardType])
  @@index([year])
  @@index([major])
  @@index([pendingStudentId])
  @@map("awards")
}

model Association {
  id              String    @id @default(uuid())
  // Attempted studentId that has no matching `Alumni` row yet — the "no Alumni
  // to link to" flag (see lib/alumni-link). Import links it once a real Alumni appears.
  studentId       String?
  pendingStudentId String?
  prefix          String?
  firstName       String
  lastName        String
  associationName String
  position        String
  recordedYear    Int
  major           String?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  alumni Alumni? @relation(fields: [studentId], references: [studentId], onDelete: Cascade)

  @@unique([studentId, associationName, position, recordedYear])
  @@index([major])
  @@index([pendingStudentId])
  @@map("associations")
}

model GraduateCommittee {
  id        String    @id @default(uuid())
  termYear  Int
  // Attempted studentId that has no matching `Alumni` row yet — the "no Alumni
  // to link to" flag (see lib/alumni-link). Import links it once a real Alumni appears.
  studentId String?
  pendingStudentId String?
  prefix    String?
  firstName String
  lastName  String
  cohort    String
  position  String
  major     String?
  remarks   String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  alumni Alumni? @relation(fields: [studentId], references: [studentId], onDelete: Cascade)

  @@unique([studentId, termYear, position])
  @@index([major])
  @@index([pendingStudentId])
  @@map("graduate_committees")
}

model News {
  id            String     @id @default(uuid())
  title         String
  body          String
  coverImageUrl String?
  status        NewsStatus @default(DRAFT)
  publishedAt   DateTime?
  pinnedAt      DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([title])
  @@map("news")
}

model Potential {
  id           String    @id @default(uuid())
  // Attempted studentId that has no matching `Alumni` row yet — the "no Alumni
  // to link to" flag (see lib/alumni-link). Import links it once a real Alumni appears.
  studentId    String?
  pendingStudentId String?
  prefix       String?
  firstName    String
  lastName     String
  career       String
  position     String
  recordedYear Int
  major        String?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  alumni Alumni? @relation(fields: [studentId], references: [studentId], onDelete: Cascade)

  @@unique([studentId, recordedYear])
  @@index([major])
  @@index([pendingStudentId])
  @@map("potentials")
}

model ModelRepresentative {
  id         String    @id @default(uuid())
  // Attempted studentId that has no matching `Alumni` row yet — the "no Alumni
  // to link to" flag (see lib/alumni-link). Import links it once a real Alumni appears.
  studentId  String?
  pendingStudentId String?
  prefix     String?
  firstName  String
  lastName   String
  cohort     String
  generation Int
  major      String?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  alumni Alumni? @relation(fields: [studentId], references: [studentId], onDelete: Cascade)

  @@unique([studentId, cohort, generation])
  @@index([major])
  @@index([pendingStudentId])
  @@map("model_representatives")
}

model AlumniAgency {
  id          String    @id @default(uuid())
  studentId   String?
  // Attempted studentId that has no matching `Alumni` row yet — the "no Alumni
  // to link to" flag. `studentId` (FK above) stays null while this is set; the
  // import moves it to `studentId` once a real Alumni appears. See lib/alumni-agency-parse.
  pendingStudentId String?
  cohort      String?
  prefix      String?
  firstName   String?
  lastName    String?
  englishName String?
  workplace   String?
  province    String? // In-country (Thailand) rows only — required at the validation layer when country is Thailand
  position    String? // ตำแหน่ง — optional for both in-country and abroad rows
  homeAddress String?
  country     String
  major       String?
  notes       String?
  order       Int
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  alumni Alumni? @relation(fields: [studentId], references: [studentId], onDelete: Cascade)

  @@index([studentId])
  @@index([pendingStudentId])
  @@index([major])
  @@map("alumni_agency")
}

model AdminUser {
  id           String    @id @default(uuid())
  firstName    String
  lastName     String
  email        String    @unique
  passwordHash String    @default("")
  role         String    @default("admin")
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions          Session[]
  activityLogs      ActivityLog[]
  tableColumnWidths TableColumnWidths[]

  @@map("admin_users")
}

/// Per-superadmin saved column widths for a management table (drag-to-resize).
/// `tableKey` may encode a view/mode suffix (e.g. "alumni-agency:thailand").
/// `widths` is a JSON map of column index (string) → px width; absent ⇒ auto.
model TableColumnWidths {
  id        String    @id @default(uuid())
  userId    String
  tableKey  String
  widths    Json
  updatedAt DateTime  @updatedAt
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tableKey])
  @@index([userId])
  @@map("table_column_widths")
}

model ActivityLog {
  id         String    @id @default(uuid())
  actorType  ActorType @default(ADMIN)
  userId     String?
  userEmail  String?
  userRole   String?
  alumniId   String?
  alumniName String?
  action     String
  resource   String
  resourceId String?
  reason     String?
  details    Json?
  createdAt  DateTime  @default(now())

  user         AdminUser?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  alumni       Alumni?             @relation(fields: [alumniId], references: [id], onDelete: SetNull)
  fieldChanges FieldChangeHistory[]

  @@index([userId])
  @@index([alumniId])
  @@index([createdAt])
  @@index([resource])
  @@index([actorType])
  @@map("activity_logs")
}

model PasswordReset {
  id        String   @id @default(uuid())
  alumniId  String
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  alumni Alumni @relation(fields: [alumniId], references: [id], onDelete: Cascade)

  @@index([alumniId])
  @@index([expiresAt])
  @@map("password_resets")
}

// Email-ownership verification tokens for the signup flow. A signup creates an
// UNVERIFIED account + one of these; clicking the link (verify-email route)
// flips the account to PENDING and marks the token used. Mirrors PasswordReset.
model EmailVerification {
  id        String   @id @default(uuid())
  alumniId  String
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  alumni Alumni @relation(fields: [alumniId], references: [id], onDelete: Cascade)

  @@index([alumniId])
  @@index([expiresAt])
  @@map("email_verifications")
}

// Per-field change history — powers the orange "updated value" indicators on
// the admin data pages and the System Logs old→new details modal (PRD §3.16).
model FieldChangeHistory {
  id           String    @id @default(uuid())
  resourceType String // matches LogResource: alumni | award | association | ...
  resourceId   String
  field        String
  oldValue     String?
  newValue     String?
  actorType    ActorType @default(ADMIN)
  userId       String?
  alumniId     String?
  actorName    String?
  reason        String?
  activityLogId String?
  createdAt     DateTime  @default(now())

  activityLog ActivityLog? @relation(fields: [activityLogId], references: [id], onDelete: SetNull)

  @@index([resourceType, resourceId, field, createdAt])
  @@index([resourceType, resourceId])
  @@index([activityLogId])
  @@map("field_change_history")
}

model Session {
  id          String      @id @default(uuid())
  userId      String?
  alumniId    String?
  token       String      @unique
  sessionType SessionType @default(ADMIN)
  expiresAt   DateTime
  createdAt   DateTime    @default(now())

  user   AdminUser? @relation(fields: [userId], references: [id], onDelete: Cascade)
  alumni Alumni?    @relation(fields: [alumniId], references: [id], onDelete: Cascade)

  @@index([alumniId])
  @@map("sessions")
}

// Local materialization of the FON-filtered CMU Registrar graduate list.
// One row per registrar DEGREE record, keyed by studentId (unique). Refreshed
// on demand by an admin from /management/cmu-sync (POST /api/cmu-alumni/sync).
// This is a faithful cache of the registrar response — the universe for the
// all-alumni table, dashboard person counts, facets, and identity checks.
// Alumni-table semantics are unchanged (Alumni = accounts / imported people).
// `birthday` is stored RAW (e.g. "01-12-1997"); read-side normalizeCmuBirthday
// canonicalizes it, identical to the live path — so dedupe/sort logic is
// byte-identical to the former live-fetch flow.
model CmuGraduate {
  id           String   @id @default(uuid())
  studentId    String   @unique
  // Core 7 (always present on a FON record):
  nameTh       String
  surnameTh    String
  birthday     String // raw registrar "DD-MM-YYYY"; normalized at read
  levelId      String
  majorNameTh  String
  gradYear     String
  // Optional enrichment (nullable — sparse in the registrar data):
  sexId        String?
  cmuitAccount String?
  nameEn       String?
  surnameEn    String?
  gradDate     String? // raw registrar grad_date string
  // Bookkeeping:
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([levelId])
  @@index([gradYear])
  @@index([majorNameTh])
  @@index([deletedAt])
  @@map("cmu_graduates")
}
