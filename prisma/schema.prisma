generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DegreeLevel {
  DOCTORAL
  MASTER
  BACHELOR
  NURSING_ASSISTANT
  ASSOCIATE
}

enum AwardType {
  INTERNATIONAL
  NATIONAL
  LOCAL
}

enum NewsStatus {
  DRAFT
  PUBLISHED
  DISCONTINUED
}

enum SessionType {
  ADMIN
  ALUMNI
}

enum ActorType {
  ADMIN
  ALUMNI
}

model Alumni {
  id                    String      @id @default(uuid())
  studentId             String      @unique
  citizenId             String?
  birthDate             String?
  prefix                String
  firstName             String
  lastName              String
  englishName           String?
  cohort                String?
  degreeLevel           DegreeLevel
  email                 String?     @unique
  phone                 String?
  major                 String?
  graduationYear        Int?
  primaryEducationId    String?  @unique
  homeAddress           String?
  remarks               String?
  isPotential           Boolean     @default(false)
  isModelRepresentative Boolean     @default(false)
  photoUrl              String?
  deletedAt             DateTime?
  suspendedAt           DateTime?
  hasLoggedIn           Boolean     @default(false)
  adminEditedAt         DateTime?
  passwordHash          String?
  lastLoginAt           DateTime?
  tosAcceptedAt         DateTime?
  cmuEmail              String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  awards               Award[]
  associations         Association[]
  graduateCommittees   GraduateCommittee[]
  potentials           Potential[]
  modelRepresentatives ModelRepresentative[]
  alumniAgency         AlumniAgency[]
  passwordResets       PasswordReset[]
  sessions             Session[]
  activityLogs         ActivityLog[]
  educations           Education[]
  primaryEducation     Education?  @relation("PrimaryEducation", fields: [primaryEducationId], references: [id], onDelete: SetNull)

  @@unique([citizenId])
  @@index([degreeLevel])
  @@index([cohort])
  @@index([major])
  @@index([graduationYear])
  @@map("alumni")
}

// One row per degree an alumni earned at FON. CMU Registrar returns one record
// per degree, so a person with a Bachelor's then a Doctoral has two rows here
// (distinct `studentId`, `degreeLevel`, `graduationYear`, `major`, `cohort`).
// `Alumni` keeps a denormalized "primary" snapshot of the chosen row
// (`studentId`/`degreeLevel`/`graduationYear`/`major`/`cohort` + the
// `primaryEducationId` pointer) so the 6 related tables (Award, Association, …)
// keep joining on `Alumni.studentId`. Keep that snapshot in sync via
// `syncPrimarySnapshot` (`lib/education-sync.ts`) — never edit it directly.
model Education {
  id             String      @id @default(uuid())
  alumniId       String
  studentId      String      @unique
  degreeLevel    DegreeLevel
  graduationYear Int?
  major          String?
  cohort         String?
  firstName      String?
  lastName       String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  alumni         Alumni      @relation(fields: [alumniId], references: [id], onDelete: Cascade)
  primaryFor     Alumni?     @relation("PrimaryEducation")

  @@unique([alumniId, degreeLevel])
  @@index([alumniId])
  @@map("education")
}

model Award {
  id            String    @id @default(uuid())
  studentId     String?
  prefix        String?
  firstName     String
  lastName      String
  awardName     String
  awardType     AwardType
  year          Int
  major         String?
  link          String?
  imageUrl      String?
  description   String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  alumni Alumni? @relation(fields: [studentId], references: [studentId], onDelete: Cascade)

  @@index([awardType])
  @@index([year])
  @@index([major])
  @@map("awards")
}

model Association {
  id              String    @id @default(uuid())
  studentId       String
  prefix          String?
  firstName       String
  lastName        String
  associationName String
  position        String
  recordedYear    Int
  major           String?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  alumni Alumni @relation(fields: [studentId], references: [studentId], onDelete: Cascade)

  @@unique([studentId, associationName, position, recordedYear])
  @@index([major])
  @@map("associations")
}

model GraduateCommittee {
  id        String    @id @default(uuid())
  termYear  Int
  studentId String
  prefix    String?
  firstName String
  lastName  String
  cohort    String
  position  String
  major     String?
  remarks   String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  alumni Alumni @relation(fields: [studentId], references: [studentId], onDelete: Cascade)

  @@unique([studentId, termYear, position])
  @@index([major])
  @@map("graduate_committees")
}

model News {
  id            String     @id @default(uuid())
  title         String
  body          String
  coverImageUrl String?
  status        NewsStatus @default(DRAFT)
  publishedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([title])
  @@map("news")
}

model Potential {
  id           String    @id @default(uuid())
  studentId    String
  prefix       String?
  firstName    String
  lastName     String
  career       String
  position     String
  recordedYear Int
  major        String?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  alumni Alumni @relation(fields: [studentId], references: [studentId], onDelete: Cascade)

  @@unique([studentId, recordedYear])
  @@index([major])
  @@map("potentials")
}

model ModelRepresentative {
  id         String    @id @default(uuid())
  studentId  String
  prefix     String?
  firstName  String
  lastName   String
  cohort     String
  generation Int
  major      String?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  alumni Alumni @relation(fields: [studentId], references: [studentId], onDelete: Cascade)

  @@unique([studentId, cohort, generation])
  @@index([major])
  @@map("model_representatives")
}

model AlumniAgency {
  id          String    @id @default(uuid())
  studentId   String?
  cohort      String?
  prefix      String?
  firstName   String?
  lastName    String?
  englishName String?
  workplace   String?
  homeAddress String?
  country     String
  major       String?
  notes       String?
  order       Int
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  alumni Alumni? @relation(fields: [studentId], references: [studentId], onDelete: Cascade)

  @@index([studentId])
  @@index([major])
  @@map("alumni_agency")
}

model AdminUser {
  id           String    @id @default(uuid())
  firstName    String
  lastName     String
  email        String    @unique
  passwordHash String    @default("")
  role         String    @default("admin")
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions     Session[]
  activityLogs ActivityLog[]

  @@map("admin_users")
}

model ActivityLog {
  id         String    @id @default(uuid())
  actorType  ActorType @default(ADMIN)
  userId     String?
  userEmail  String?
  userRole   String?
  alumniId   String?
  alumniName String?
  action     String
  resource   String
  resourceId String?
  reason     String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime  @default(now())

  user   AdminUser? @relation(fields: [userId], references: [id], onDelete: Cascade)
  alumni Alumni?    @relation(fields: [alumniId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([alumniId])
  @@index([createdAt])
  @@index([resource])
  @@index([actorType])
  @@map("activity_logs")
}

model PasswordReset {
  id        String   @id @default(uuid())
  alumniId  String
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  alumni Alumni @relation(fields: [alumniId], references: [id], onDelete: Cascade)

  @@index([alumniId])
  @@index([expiresAt])
  @@map("password_resets")
}

// Per-field change history — powers the orange "updated value" indicators on
// the admin data pages and the System Logs old→new details modal (PRD §3.16).
model FieldChangeHistory {
  id           String    @id @default(uuid())
  resourceType String // matches LogResource: alumni | award | association | ...
  resourceId   String
  field        String
  oldValue     String?
  newValue     String?
  actorType    ActorType @default(ADMIN)
  userId       String?
  alumniId     String?
  actorName    String?
  reason       String?
  createdAt    DateTime  @default(now())

  @@index([resourceType, resourceId, field, createdAt])
  @@index([resourceType, resourceId])
  @@map("field_change_history")
}

model Session {
  id          String      @id @default(uuid())
  userId      String?
  alumniId    String?
  token       String      @unique
  sessionType SessionType @default(ADMIN)
  expiresAt   DateTime
  createdAt   DateTime    @default(now())

  user   AdminUser? @relation(fields: [userId], references: [id], onDelete: Cascade)
  alumni Alumni?    @relation(fields: [alumniId], references: [id], onDelete: Cascade)

  @@index([alumniId])
  @@map("sessions")
}
