# =========================================================================
# .env.example — environment variable template.
#
# Copy this file to `.env` and fill in real values. `.env` itself is
# gitignored and MUST NOT be committed — the values below are placeholders.
#
# Every variable the application reads is listed here. Grouped by concern.
# =========================================================================

# -------------------------------------------------------------------------
# Database
#   PostgreSQL connection string used by Prisma + the app (lib/prisma.ts).
#   The local Docker Postgres is the default dev target — start it with
#   `docker compose up -d db`. A remote Prisma Postgres URL may be used
#   instead in production. Must agree with the POSTGRES_* values below.
# -------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/defaultdb"

# PostgreSQL container credentials (read by docker-compose.yml).
# Keep USER/PASSWORD/DB in sync with DATABASE_URL.
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="changeme"
POSTGRES_DB="defaultdb"

# pgAdmin container credentials (optional, docker-compose.yml).
PGADMIN_DEFAULT_EMAIL="admin@example.com"
PGADMIN_DEFAULT_PASSWORD="changeme"

# -------------------------------------------------------------------------
# CMU OAuth2 — staff/admin single sign-on via Microsoft Entra ID (PKCE).
#   The app runs under basePath "/alumni", so the callback path is
#   /alumni/api/auth/callback. CALLBACK_URL must match the redirect URI
#   registered in Microsoft Entra ID and is read by BOTH the authorize
#   request and the token exchange (lib/oauth.ts).
# -------------------------------------------------------------------------
AUTH_URL=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/authorize
TOKEN_URL=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/token
CALLBACK_URL=http://localhost:3000/alumni/api/auth/callback
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret
SCOPE=api://cmu/Mis.Account.Read.Me.Basicinfo offline_access
BASICINFO_URL=https://api.cmu.ac.th/mis/cmuaccount/prod/v3/me/basicinfo
LOGOUT_URL=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/logout?post_logout_redirect_uri=http://localhost:3000/

# -------------------------------------------------------------------------
# Public base URL
#   Used for password-reset links and OAuth error redirects (lib/email.ts,
#   auth routes). Exposed to the client (NEXT_PUBLIC_*).
# -------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# -------------------------------------------------------------------------
# Email (Resend primary, nodemailer/SMTP fallback) — alumni emails (lib/email.ts):
# email verification, password reset, signup approved/rejected.
#   * RESEND_API_KEY: when set, all alumni mail is sent via Resend.
#     RESEND_FROM must be an address on a VERIFIED Resend sending domain
#     (for local testing use "onboarding@resend.dev").
#   * SMTP_*: nodemailer fallback used only when RESEND_API_KEY is absent.
#     Defaults if omitted: SMTP_PORT -> 587, SMTP_SECURE -> false.
# -------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM="FON CMU Alumni <onboarding@resend.dev>"
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="FON CMU Alumni <no-reply@example.com>"

# -------------------------------------------------------------------------
# CMU Registrar API (student_grad) — source of FON graduate records.
#   Feeds the CMU materialize/sync, signup verification, and lookups
#   (lib/cmu-registrar.ts). CMU_FON_FACULTY_ID defaults to "12"
#   (Faculty of Nursing) when unset.
# -------------------------------------------------------------------------
CMU_REG_API_BASE_URL=https://apiservice.reg.cmu.ac.th/student_grad
CMU_REG_API_TOKEN=your-registrar-api-token
CMU_REG_API_ACCOUNT_NAME=your.account.name
CMU_REG_API_ID=00000
CMU_FON_FACULTY_ID=12

# -------------------------------------------------------------------------
# Shared secrets (generate with: openssl rand -base64 32)
#   CLEANUP_SECRET  — Bearer token for GET /api/auth/cleanup (expired-session
#                     sweep). The route returns 503 if this is unset.
#   CMU_SYNC_SECRET — Bearer token for POST/GET /api/cmu-alumni/sync
#                     (materialize CMU graduates). Optional: when unset the
#                     sync route falls back to admin-session auth.
# -------------------------------------------------------------------------
CLEANUP_SECRET=replace-with-openssl-rand-base64-32
CMU_SYNC_SECRET=replace-with-openssl-rand-base64-32
